  "item": [
    {
      "name": "Home",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Has endpoints list', function () {",
              "  const data = pm.response.json();",
              "  pm.expect(data).to.have.property('endpoints');",
              "  pm.expect(data.endpoints).to.include('/getAll');",
              "});"
            ]
          }
        }
      ]
    },
