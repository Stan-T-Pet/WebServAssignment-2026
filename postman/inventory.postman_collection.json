{
  "info": {
    "name": "Inventory API Collection",
    "_postman_id": "d5f52c27-2ec0-4f30-91cf-7df4a2b46f01",
    "description": "Postman tests for the Web Services inventory API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Home",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Has API running message', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.eql('Inventory API is running');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
